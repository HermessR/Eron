{
  "projectMetadata": {
    "name": "AITT",
    "fullName": "Automation Integration Test Tool",
    "description": "Desktop application for integration testing of aeronautical embedded systems",
    "version": "1.0.0",
    "organization": "com.aerospace",
    "language": "Java 20",
    "framework": "JavaFX 20.0.2",
    "buildTool": "Maven",
    "targetPlatform": "Windows 10/11 (x64)",
    "type": "Desktop GUI Application"
  },
  
  "architecture": {
    "overview": "Layered MVC architecture with native interop for hardware communication",
    "layers": {
      "presentation": {
        "name": "Presentation Layer (JavaFX UI)",
        "description": "Desktop UI controllers and views for user interaction",
        "technology": "JavaFX FXML",
        "responsibilities": [
          "User interface rendering",
          "Event handling and user input",
          "Real-time UI updates",
          "Cross-module navigation"
        ],
        "components": {
          "shell": {
            "description": "Application shell and navigation",
            "classes": [
              {
                "name": "MainApp",
                "file": "shell/MainApp.java",
                "purpose": "JavaFX Application entry point",
                "responsibilities": [
                  "Initialize JavaFX stage",
                  "Pre-warm native library",
                  "Show login screen",
                  "Manage application lifecycle"
                ]
              },
              {
                "name": "LoginController",
                "file": "shell/LoginController.java",
                "purpose": "User authentication UI",
                "responsibilities": ["Credential input", "Session initiation"]
              },
              {
                "name": "DashboardController",
                "file": "shell/DashboardController.java",
                "purpose": "Main dashboard navigation hub",
                "responsibilities": [
                  "Module navigation",
                  "Dashboard layout",
                  "Module switching"
                ]
              },
              {
                "name": "ModuleLoader",
                "file": "shell/ModuleLoader.java",
                "purpose": "Dynamic module loading and initialization",
                "responsibilities": ["Runtime module discovery", "FXML loading"]
              }
            ]
          },
          "flashing": {
            "description": "Firmware flashing UI module",
            "classes": [
              {
                "name": "FlashingController",
                "file": "flashing/ui/FlashingController.java",
                "purpose": "Firmware flashing interface",
                "responsibilities": [
                  "Module selection and validation",
                  "Progress monitoring",
                  "CMM script execution control",
                  "Abort functionality"
                ]
              }
            ]
          },
          "hardware": {
            "description": "Local hardware probe management UI",
            "classes": [
              {
                "name": "HardwareController",
                "file": "hardware/ui/HardwareController.java",
                "purpose": "USB/JTAG debug probe interface",
                "responsibilities": [
                  "Probe discovery and listing",
                  "Connection management",
                  "Command execution",
                  "Real-time logging"
                ]
              }
            ]
          },
          "remote": {
            "description": "Network probe management UI",
            "classes": [
              {
                "name": "RemoteProbeController",
                "file": "remote/ui/RemoteProbeController.java",
                "purpose": "Network debug probe interface",
                "responsibilities": [
                  "Network probe discovery",
                  "Remote connection management",
                  "Remote command execution"
                ]
              }
            ]
          },
          "scripting": {
            "description": "CMM script editing and execution UI",
            "classes": [
              {
                "name": "ScriptingController",
                "file": "scripting/ui/ScriptingController.java",
                "purpose": "TRACE32 CMM script editor",
                "responsibilities": [
                  "Script composition",
                  "Syntax assistance",
                  "Script execution"
                ]
              }
            ]
          },
          "config": {
            "description": "Application configuration UI",
            "classes": [
              {
                "name": "SettingsController",
                "file": "core/config/ui/SettingsController.java",
                "purpose": "Application preferences interface",
                "responsibilities": [
                  "TRACE32 path configuration",
                  "Visual theme selection",
                  "Flashing defaults",
                  "Output preferences"
                ]
              },
              {
                "name": "ConfigController",
                "file": "config/ui/ConfigController.java",
                "purpose": "Advanced configuration options",
                "responsibilities": ["Expert-level settings"]
              }
            ]
          },
          "testdev": {
            "description": "Development and testing UI",
            "classes": [
              {
                "name": "TestDevController",
                "file": "testdev/ui/TestDevController.java",
                "purpose": "Development testing interface",
                "responsibilities": ["Feature testing", "Integration testing"]
              }
            ]
          }
        }
      },

      "applicationLogic": {
        "name": "Application Logic Layer",
        "description": "Business logic and orchestration services",
        "technology": "Java Services Pattern",
        "responsibilities": [
          "Business process orchestration",
          "Cross-module coordination",
          "State management",
          "Event distribution"
        ],
        "components": {
          "flashingService": {
            "description": "Main orchestrator for firmware flashing operations",
            "classes": [
              {
                "name": "FlashingService",
                "file": "flashing/service/FlashingService.java",
                "purpose": "Flashing process orchestration",
                "responsibilities": [
                  "Coordinate validation, generation, and execution",
                  "Manage flashing sessions",
                  "Async operation handling",
                  "Abort and recovery logic"
                ],
                "dependencies": [
                  "Validator",
                  "CmmGenerator",
                  "Trace32Runner",
                  "SessionStore",
                  "ProfileStore"
                ],
                "publicMethods": [
                  "validate(modules, target) -> ValidationResult",
                  "execute(modules, target, outputPath, runTrace32, trace32Path, logCallback, progressCallback) -> CompletableFuture<FlashingSession>",
                  "abort()",
                  "getCurrentSession() -> FlashingSession"
                ]
              },
              {
                "name": "Validator",
                "file": "flashing/service/Validator.java",
                "purpose": "Firmware module validation against target",
                "responsibilities": [
                  "Memory address conflict detection",
                  "Module compatibility checking",
                  "Target profile validation"
                ]
              },
              {
                "name": "CmmGenerator",
                "file": "flashing/service/CmmGenerator.java",
                "purpose": "TRACE32 CMM script generation",
                "responsibilities": [
                  "CMM command sequence generation",
                  "Chipset-specific code generation",
                  "Script output formatting"
                ]
              },
              {
                "name": "Trace32Runner",
                "file": "flashing/service/Trace32Runner.java",
                "purpose": "TRACE32 external process management",
                "responsibilities": [
                  "Process invocation",
                  "Process monitoring",
                  "Output capture",
                  "Error handling"
                ]
              }
            ]
          },
          
          "hardwareService": {
            "description": "Hardware probe management and communication",
            "classes": [
              {
                "name": "HardwareService",
                "file": "native_/HardwareService.java",
                "purpose": "High-level hardware operations wrapper",
                "responsibilities": [
                  "Async operation support",
                  "Connection state management",
                  "Event callbacks for UI",
                  "Automatic reconnection",
                  "Probe discovery and enumeration"
                ],
                "dependencies": ["HardwareBridge"],
                "publicMethods": [
                  "discoverProbes() -> CompletableFuture<List<ProbeInfo>>",
                  "connect(probeId, chipset) -> CompletableFuture<Void>",
                  "disconnect() -> CompletableFuture<Void>",
                  "sendCommand(cmd) -> CompletableFuture<CommandResult>",
                  "readMemory(address, length) -> CompletableFuture<byte[]>",
                  "writeMemory(address, data) -> CompletableFuture<Void>"
                ],
                "events": [
                  "ConnectionEvent(state, probeId, message)",
                  "LogEvent(message)"
                ]
              }
            ]
          },
          
          "networkProbeService": {
            "description": "Network-attached debug probe discovery and management",
            "classes": [
              {
                "name": "NetworkProbeService",
                "file": "remote/service/NetworkProbeService.java",
                "purpose": "TCP/IP debug probe management",
                "responsibilities": [
                  "UDP broadcast discovery",
                  "Direct TCP connection",
                  "Subnet scanning",
                  "DNS-SD discovery",
                  "Keep-alive management",
                  "Connection pooling"
                ],
                "discoveryMethods": [
                  "UDP broadcast for AITT probe servers",
                  "Direct TCP to known addresses",
                  "Subnet scanning for TRACE32 units",
                  "mDNS/DNS-SD discovery"
                ]
              },
              {
                "name": "RemoteFlashingService",
                "file": "remote/service/RemoteFlashingService.java",
                "purpose": "Remote flashing over network",
                "responsibilities": [
                  "Remote flashing coordination",
                  "Network reliability",
                  "Remote command execution"
                ]
              }
            ]
          },
          
          "authenticationService": {
            "description": "User authentication and session management",
            "classes": [
              {
                "name": "AuthService",
                "file": "core/auth/AuthService.java",
                "purpose": "User authentication and authorization",
                "pattern": "Singleton",
                "responsibilities": [
                  "Credential validation",
                  "Session creation",
                  "User role assignment",
                  "Future: License validation"
                ]
              }
            ]
          }
        }
      },

      "businessLogic": {
        "name": "Business Logic & Data Models",
        "description": "Core business entities and domain logic",
        "components": {
          "flashingDomain": {
            "description": "Firmware flashing domain models",
            "classes": [
              {
                "name": "FlashingSession",
                "file": "flashing/model/FlashingSession.java",
                "purpose": "Represents a single flashing operation",
                "properties": [
                  "sessionId",
                  "modules: List<SoftwareModule>",
                  "targetProfile: TargetProfile",
                  "status: FlashStatus",
                  "generatedScript: Path",
                  "startTime: LocalDateTime",
                  "endTime: LocalDateTime"
                ]
              },
              {
                "name": "SoftwareModule",
                "file": "flashing/model/SoftwareModule.java",
                "purpose": "Firmware module with binary and metadata",
                "properties": [
                  "name: String",
                  "version: String",
                  "binaryPath: Path",
                  "baseAddress: long",
                  "size: long",
                  "checksum: String"
                ]
              },
              {
                "name": "TargetProfile",
                "file": "flashing/model/TargetProfile.java",
                "purpose": "Chipset memory map and configuration",
                "pattern": "Record",
                "properties": [
                  "id: String",
                  "name: String",
                  "cpuType: String",
                  "flashStart: long",
                  "flashEnd: long",
                  "ramAddress: long",
                  "t32ConfigPath: Path"
                ]
              },
              {
                "name": "FlashStatus",
                "file": "flashing/model/FlashStatus.java",
                "purpose": "Flashing execution status enumeration",
                "values": [
                  "IDLE",
                  "VALIDATING",
                  "GENERATING",
                  "EXECUTING",
                  "COMPLETED",
                  "FAILED",
                  "ABORTED"
                ]
              },
              {
                "name": "ValidationResult",
                "file": "flashing/model/ValidationResult.java",
                "purpose": "Validation outcome with details",
                "properties": [
                  "valid: boolean",
                  "errors: List<String>",
                  "warnings: List<String>"
                ]
              }
            ]
          },

          "hardwareDomain": {
            "description": "Hardware communication domain models",
            "classes": [
              {
                "name": "HardwareInfo",
                "file": "native_/HardwareInfo.java",
                "purpose": "Hardware capability and status information",
                "properties": [
                  "probeId: String",
                  "probeType: ProbeType",
                  "serialNumber: String",
                  "firmwareVersion: String",
                  "supportedChipsets: List<String>"
                ]
              },
              {
                "name": "CommandResult",
                "file": "native_/CommandResult.java",
                "purpose": "Hardware command execution result",
                "properties": [
                  "success: boolean",
                  "message: String",
                  "data: byte[]",
                  "errorCode: int"
                ]
              },
              {
                "name": "ChipsetConfig",
                "file": "native_/ChipsetConfig.java",
                "purpose": "Chipset-specific configuration",
                "properties": [
                  "chipsetId: String",
                  "debugPort: String",
                  "debugFrequency: int",
                  "resetType: String"
                ]
              }
            ]
          },

          "remoteDomain": {
            "description": "Network probe domain models",
            "classes": [
              {
                "name": "NetworkProbe",
                "file": "remote/model/NetworkProbe.java",
                "purpose": "Network-accessible debug probe",
                "properties": [
                  "id: String",
                  "hostname: String",
                  "ipAddress: String",
                  "port: int",
                  "probeType: RemoteType",
                  "connectionStatus: ConnectionStatus",
                  "lastSeen: LocalDateTime"
                ],
                "enums": {
                  "RemoteType": ["AITT_SERVER", "TRACE32_UNIT", "GENERIC_TCP"],
                  "ConnectionStatus": ["AVAILABLE", "CONNECTED", "DISCONNECTED", "ERROR"]
                }
              }
            ]
          },

          "authenticationDomain": {
            "description": "User and authentication domain",
            "classes": [
              {
                "name": "User",
                "file": "core/auth/User.java",
                "purpose": "Authenticated user representation",
                "properties": [
                  "username: String",
                  "displayName: String",
                  "role: UserRole",
                  "loginTime: LocalDateTime"
                ]
              }
            ]
          }
        }
      },

      "supportingLayers": {
        "name": "Supporting & Cross-Cutting Layers",
        "description": "Configuration, utilities, logging, and infrastructure",
        "components": {
          "configuration": {
            "description": "Application settings and configuration management",
            "classes": [
              {
                "name": "AppSettings",
                "file": "core/config/AppSettings.java",
                "purpose": "Centralized application preferences",
                "categories": {
                  "trace32": [
                    "executable_path",
                    "connection_timeout"
                  ],
                  "flashing": [
                    "default_target_profile",
                    "auto_validate",
                    "confirm_before_flash"
                  ],
                  "output": [
                    "default_directory",
                    "auto_generate_filename",
                    "open_after_generate"
                  ],
                  "appearance": [
                    "theme",
                    "log_max_lines",
                    "show_timestamp",
                    "wrap_log_text"
                  ]
                }
              },
              {
                "name": "SettingsStore",
                "file": "core/config/SettingsStore.java",
                "purpose": "Persistent settings storage",
                "responsibilities": [
                  "JSON serialization/deserialization",
                  "File I/O management",
                  "Settings change notifications"
                ]
              }
            ]
          },

          "dataManagement": {
            "description": "Persistent data storage for sessions and profiles",
            "classes": [
              {
                "name": "SessionStore",

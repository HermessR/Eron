  "dataFlow": {
    "flashingWorkflow": {
      "description": "Typical firmware flashing workflow",
      "steps": [
        {
          "step": 1,
          "actor": "User",
          "action": "Select firmware modules and target profile"
        },
        {
          "step": 2,
          "actor": "FlashingService",
          "action": "Validate modules against target profile"
        },
        {
          "step": 3,
          "actor": "Validator",
          "action": "Check memory addresses, compatibility"
        },
        {
          "step": 4,
          "actor": "CmmGenerator",
          "action": "Generate TRACE32 CMM script"
        },
        {
          "step": 5,
          "actor": "Trace32Runner",
          "action": "Execute CMM script via TRACE32"
        },
        {
          "step": 6,
          "actor": "SessionStore",
          "action": "Archive session for history"
        },
        {
          "step": 7,
          "actor": "UI",
          "action": "Display results and completion status"
        }
      ],
      "errorHandling": [
        "Validation failure -> Stop with error message",
        "TRACE32 not found -> Show configuration dialog",
        "Script execution error -> Capture output and display",
        "User abort -> Graceful shutdown"
      ]
    },

    "hardwareConnectionWorkflow": {
      "description": "Hardware probe discovery and connection",
      "steps": [
        {
          "step": 1,
          "actor": "HardwareService",
          "action": "Initialize hardware bridge"
        },
        {
          "step": 2,
          "actor": "HardwareBridge",
          "action": "Call JNI to scan for probes"
        },
        {
          "step": 3,
          "actor": "Native Library",
          "action": "Enumerate USB/serial ports"
        },
        {
          "step": 4,
          "actor": "Native Library",
          "action": "Communicate with each probe"
        },
        {
          "step": 5,
          "actor": "HardwareService",
          "action": "Fire discovery events"
        },
        {
          "step": 6,
          "actor": "UI",
          "action": "Display available probes"
        },
        {
          "step": 7,
          "actor": "User",
          "action": "Select probe and chipset"
        },
        {
          "step": 8,
          "actor": "HardwareService",
          "action": "Connect with selected config"
        }
      ]
    }
  },


                ]
              }
            ]
          }
        }
      },

      "nativeLayer": {
        "name": "Native Integration Layer (C/C++)",
        "description": "JNI bridge to native hardware communication",
        "technology": "C, JNI, CMake, Visual Studio",
        "targetOS": "Windows 10/11 x64",
        "components": {
          "jniBridge": {
            "description": "Java Native Interface bindings",
            "files": [
              {
                "name": "aitt_native.h",
                "path": "native/include/aitt_native.h",
                "purpose": "Public C API definition",
                "scope": "Header-only"
              },
              {
                "name": "aitt_native.c",
                "path": "native/src/aitt_native.c",
                "purpose": "Core native implementation",
                "responsibilities": [
                  "Probe initialization and discovery",
                  "Communication protocol handling",
                  "Memory management",
                  "Driver registration"
                ]
              },
              {
                "name": "jni_bindings.c",
                "path": "native/src/jni_bindings.c",
                "purpose": "JNI method implementations",
                "responsibilities": [
                  "Java call handling",
                  "Type conversion (Java <-> C)",
                  "Exception propagation",
                  "Callback management"
                ],
                "jniMethods": [
                  "Java_com_aerospace_aitt_native__HardwareBridge_discoverProbes",
                  "Java_com_aerospace_aitt_native__HardwareBridge_connect",
                  "Java_com_aerospace_aitt_native__HardwareBridge_sendCommand",
                  "Java_com_aerospace_aitt_native__HardwareBridge_readMemory",
                  "Java_com_aerospace_aitt_native__HardwareBridge_writeMemory"
                ]
              }
            ]
          },

          "chipsetDrivers": {
            "description": "Hardware-specific driver implementations",
            "files": [
              {
                "name": "chipset_s32k148.c",
                "path": "native/src/chipset_s32k148.c",
                "purpose": "NXP S32K148 ARM Cortex-M4F driver",
                "chipset": {
                  "id": "S32K148",
                  "architecture": "ARM Cortex-M4F",
                  "debugInterface": "SWD (Serial Wire Debug)",
                  "flashStart": "0x00000000",
                  "flashSize": "2MB",
                  "ramSize": "512KB"
                },
                "capabilities": [
                  "SWD connection",
                  "Memory read/write",
                  "Register access",
                  "Flash programming",
                  "Breakpoint management"
                ]
              },
              {
                "name": "chipset_mpc5777m.c",
                "path": "native/src/chipset_mpc5777m.c",
                "purpose": "NXP MPC5777M Power ISA dual-core driver",
                "chipset": {
                  "id": "MPC5777M",
                  "architecture": "Power ISA (e500v2)",
                  "cores": 2,
                  "debugInterface": "JTAG",
                  "flashStart": "0x00000000",
                  "flashSize": "4MB",
                  "ramSize": "768KB"
                },
                "capabilities": [
                  "JTAG connection",
                  "Multi-core debugging",
                  "Memory read/write",
                  "Dual-core synchronization",
                  "Flash programming"
                ]
              }
            ]
          },

          "nativeBridge": {
            "description": "Java class wrapping native interface",
            "classes": [
              {
                "name": "HardwareBridge",
                "file": "native_/HardwareBridge.java",
                "purpose": "Low-level JNI wrapper",
                "pattern": "Singleton",
                "nativeMethods": [
                  "native void init() throws NativeException",
                  "native void shutdown()",
                  "native ProbeInfo[] discoverProbes() throws NativeException",
                  "native void connect(String probeId, ChipsetConfig config) throws NativeException",
                  "native void disconnect()",
                  "native CommandResult sendCommand(String command) throws NativeException",
                  "native byte[] readMemory(long address, int length) throws NativeException",
                  "native void writeMemory(long address, byte[] data) throws NativeException"
                ],
                "dllFile": "windows-x64/aitt_native.dll"
              },
              {
                "name": "NativeException",
                "file": "native_/NativeException.java",
                "purpose": "Native layer exception wrapper",
                "responsibilities": ["Error propagation"]
              }
            ]
          }
        }
      }
    }
  },

  "featureModules": {

                ]
              },
              {
                "name": "ThemeManager",
                "file": "core/ui/ThemeManager.java",
                "purpose": "Application theming (dark/light modes)",
                "responsibilities": [
                  "CSS stylesheet management",
                  "Theme switching",
                  "Persistence of theme choice"
                ]
              },
              {
                "name": "Alerts",
                "file": "core/ui/Alerts.java",
                "purpose": "Dialog and alert utilities",
                "methods": [
                  "showInfo(title, message)",
                  "showWarning(title, message)",
                  "showError(title, message)",
                  "showConfirmation(title, message) -> boolean"
                ]
              },
              {
                "name": "InfiniteCarousel",
                "file": "core/ui/InfiniteCarousel.java",
                "purpose": "Reusable carousel UI component",
                "responsibilities": ["Item display", "Navigation"]
              }
            ]
          },

          "logging": {
            "description": "Structured logging and debugging",
            "classes": [
              {
                "name": "AppLogger",
                "file": "core/log/AppLogger.java",
                "purpose": "Application-wide logging facade",
                "backend": "Logback SLF4J",
                "levels": [
                  "DEBUG",
                  "INFO",
                  "WARN",
                  "ERROR"
                ],
                "features": [
